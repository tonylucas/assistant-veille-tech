# Application
APP_ENV=development
LOG_LEVEL=INFO

# Azure AI Inference (LLM)
AZURE_AI_INFERENCE_ENDPOINT=
AZURE_AI_INFERENCE_API_KEY=
AZURE_AI_INFERENCE_MODEL=Kimi-K2.6

# ChromaDB (host port: 8002 ; service-to-service: chromadb:8000)
CHROMA_URL=http://chromadb:8000
CHROMA_COLLECTION=articles
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# NewsAPI
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2

# Twitter
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=
TWITTER_COOKIES_PATH=data/twitter_cookies.json

# Backend ↔ Frontend
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
